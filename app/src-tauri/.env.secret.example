# Secrets — copy to .env.secret (gitignored). Public IDs go in .env.

# Google requires client_secret for Desktop OAuth client type even with PKCE.
# Their docs note this "isn't, by definition, a secret" because it ships in
# every native binary, but treat it as one anyway — keep it out of git.
MLMAIL_GOOGLE_DESKTOP_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
